# Multi-DB Connect Configuration for Portfolio Demo

# Supabase Configuration (for projects and blog posts)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Firebase Configuration (for skills and achievements)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id

# MongoDB Configuration (for portfolio analytics)
VITE_MONGODB_URI=mongodb://localhost:27017
VITE_MONGODB_DATABASE=portfolio

# REST API Configuration (for external data)
VITE_API_BASE_URL=https://api.github.com
VITE_GITHUB_TOKEN=your-github-token

# Default Provider
VITE_DEFAULT_DB_PROVIDER=supabase



